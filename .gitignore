# Rust build artifacts (matches target/ at any depth, in root or any subdir)
**/target/

# Backup files generated by rustfmt
**/*.rs.bk

# Cargo.lock: keep tracked for binaries (default here).
# If any nested crate is a pure library meant for publishing,
# add a crate-specific override below instead of un-ignoring globally, e.g.:
# some-library-crate/Cargo.lock

# Editor/OS cruft
.DS_Store
*.swp
